@page "/health"
@using FitnessTracker.Services
@using FitnessTracker.Models
@inject FitnessService Fitness
@inject ClientStateService State
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Health Metrics – FitTrack</PageTitle>

@if (!_ready) { <div class="skeleton-card"></div> }
else if (!State.IsLoggedIn) { <div class="skeleton-card"></div> }
else
{
    <div class="page-header">
        <div>
            <h1>Health Metrics</h1>
            <p class="subtitle">Daily health tracking</p>
        </div>
        <button class="btn-primary" @onclick="() => showForm = !showForm">
            @(showForm ? "✕ Cancel" : "+ Log Today")
        </button>
    </div>

    @if (showForm)
    {
        <div class="card form-card">
            <h2>Record Health Data</h2>
            <div class="form-grid">
                <div class="form-group">
                    <label>Date</label>
                    <input type="date" @bind="recordDate" />
                </div>
                <div class="form-group">
                    <label>Weight (kg)</label>
                    <input type="number" @bind="newMetric.WeightKg" step="0.1" min="0" />
                </div>
                <div class="form-group">
                    <label>Heart Rate (bpm)</label>
                    <input type="number" @bind="newMetric.HeartRateBpm" min="0" />
                </div>
                <div class="form-group">
                    <label>Sleep (hours)</label>
                    <input type="number" @bind="newMetric.SleepHours" step="0.5" min="0" max="24" />
                </div>
                <div class="form-group">
                    <label>Water Intake (liters)</label>
                    <input type="number" @bind="newMetric.WaterIntakeLiters" step="0.1" min="0" />
                </div>
            </div>
            <button class="btn-primary" @onclick="SaveMetric">Save</button>
        </div>
    }

    @if (metrics == null) { <div class="skeleton-card"></div> }
    else if (!metrics.Any())
    {
        <div class="empty-state"><span>📊</span><p>No health data recorded yet.</p></div>
    }
    else
    {
        <div class="table-card">
            <table class="data-table">
                <thead>
                    <tr><th>Date</th><th>⚖️ Weight</th><th>❤️ Heart Rate</th><th>💤 Sleep</th><th>💧 Water</th></tr>
                </thead>
                <tbody>
                    @foreach (var m in metrics)
                    {
                        <tr>
                            <td>@m.RecordDate.ToString("MMM d, yyyy")</td>
                            <td>@(m.WeightKg.HasValue ? $"{m.WeightKg} kg" : "—")</td>
                            <td>@(m.HeartRateBpm.HasValue ? $"{m.HeartRateBpm} bpm" : "—")</td>
                            <td>@(m.SleepHours.HasValue ? $"{m.SleepHours} h" : "—")</td>
                            <td>@(m.WaterIntakeLiters.HasValue ? $"{m.WaterIntakeLiters} L" : "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@code {
    List<HealthMetric>? metrics;
    HealthMetric newMetric = new();
    DateOnly recordDate = DateOnly.FromDateTime(DateTime.Today);
    bool showForm = false, _ready = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await State.LoadFromSessionAsync();
        _ready = true;
        if (!State.IsLoggedIn) { Nav.NavigateTo("/login"); return; }
        metrics = await Fitness.GetMetricsAsync(State.CurrentClient!.ClientId);
        StateHasChanged();
    }

    async Task SaveMetric()
    {
        newMetric.ClientId = State.CurrentClient!.ClientId;
        newMetric.RecordDate = recordDate;
        await Fitness.AddMetricAsync(newMetric);
        newMetric = new(); recordDate = DateOnly.FromDateTime(DateTime.Today); showForm = false;
        metrics = await Fitness.GetMetricsAsync(State.CurrentClient!.ClientId);
    }
}