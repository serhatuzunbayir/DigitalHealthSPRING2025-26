<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DigitalHealthTrainer.App">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Colors -->
            <Color x:Key="Primary">#4F46E5</Color>
            <Color x:Key="PrimaryDark">#4338CA</Color>
            <Color x:Key="Success">#059669</Color>
            <Color x:Key="Warning">#D97706</Color>
            <Color x:Key="Danger">#DC2626</Color>
            <Color x:Key="Sidebar">#1E293B</Color>
            <Color x:Key="CardBg">#FFFFFF</Color>
            <Color x:Key="PageBg">#F8F9FC</Color>
            <Color x:Key="TextPrimary">#1E293B</Color>
            <Color x:Key="TextSecondary">#64748B</Color>
            <Color x:Key="TextMuted">#94A3B8</Color>
            <Color x:Key="Border">#E2E8F0</Color>
            <Color x:Key="GreenBg">#F0FDF4</Color>
            <Color x:Key="YellowBg">#FFFBEB</Color>
            <Color x:Key="RedBg">#FEF2F2</Color>

            <!-- Styles -->
            <Style TargetType="Button" x:Key="PrimaryBtn">
                <Setter Property="BackgroundColor" Value="{StaticResource Primary}"/>
                <Setter Property="TextColor" Value="White"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="16,10"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>
            <Style TargetType="Button" x:Key="SuccessBtn">
                <Setter Property="BackgroundColor" Value="{StaticResource Success}"/>
                <Setter Property="TextColor" Value="White"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="16,10"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>
            <Style TargetType="Button" x:Key="DangerBtn">
                <Setter Property="BackgroundColor" Value="{StaticResource Danger}"/>
                <Setter Property="TextColor" Value="White"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="16,10"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>
            <Style TargetType="Button" x:Key="NavBtn">
                <Setter Property="BackgroundColor" Value="Transparent"/>
                <Setter Property="TextColor" Value="#CBD5E1"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="14,10"/>
                <Setter Property="HorizontalOptions" Value="Fill"/>
            </Style>
            <Style TargetType="Button" x:Key="NavActiveBtn">
                <Setter Property="BackgroundColor" Value="{StaticResource Primary}"/>
                <Setter Property="TextColor" Value="White"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="14,10"/>
                <Setter Property="HorizontalOptions" Value="Fill"/>
            </Style>
            <Style TargetType="Entry" x:Key="ModernEntry">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="TextColor" Value="#1E293B"/>
                <Setter Property="PlaceholderColor" Value="#94A3B8"/>
                <Setter Property="BackgroundColor" Value="#F1F5F9"/>
                <Setter Property="MinimumHeightRequest" Value="44"/>
            </Style>
            <Style TargetType="Editor" x:Key="ModernEditor">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="TextColor" Value="#1E293B"/>
                <Setter Property="PlaceholderColor" Value="#94A3B8"/>
                <Setter Property="BackgroundColor" Value="#F1F5F9"/>
            </Style>
            <!-- Global Picker style — fixes black-on-dark readability issue -->
            <Style TargetType="Picker">
                <Setter Property="BackgroundColor" Value="#F1F5F9"/>
                <Setter Property="TextColor" Value="#1E293B"/>
                <Setter Property="TitleColor" Value="#94A3B8"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="MinimumHeightRequest" Value="44"/>
            </Style>
            <!-- Global DatePicker style -->
            <Style TargetType="DatePicker">
                <Setter Property="BackgroundColor" Value="#F1F5F9"/>
                <Setter Property="TextColor" Value="#1E293B"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="MinimumHeightRequest" Value="44"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
