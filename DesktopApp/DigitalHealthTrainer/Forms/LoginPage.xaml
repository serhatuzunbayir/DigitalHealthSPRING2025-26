<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DigitalHealthTrainer.Forms.LoginPage"
             BackgroundColor="{StaticResource PageBg}"
             Title="Digital Health Trainer">

    <!-- Login Card -->
    <Border BackgroundColor="White"
            Stroke="{StaticResource Border}" StrokeThickness="1"
            StrokeShape="RoundRectangle 16"
            Padding="36,32" Margin="60,40" VerticalOptions="Center"
            MaximumWidthRequest="420" HorizontalOptions="Center">
        <Border.Shadow>
            <Shadow Brush="#20000000" Offset="0,4" Radius="16" Opacity="0.35"/>
        </Border.Shadow>
        <VerticalStackLayout Spacing="10">
            <!-- Header -->
            <Label Text="💪" FontSize="44" HorizontalOptions="Center"/>
            <Label x:Name="lblTitle" Text="Trainer Login" FontSize="26" FontAttributes="Bold"
                   TextColor="{StaticResource Primary}" HorizontalOptions="Center"/>
            <Label Text="Digital Health &amp; Fitness Tracker" FontSize="13"
                   TextColor="{StaticResource TextMuted}" HorizontalOptions="Center" Margin="0,0,0,14"/>

            <!-- Username -->
            <Label x:Name="lblUsername" Text="Username" TextColor="{StaticResource TextSecondary}"
                   FontSize="13" FontAttributes="Bold" Margin="2,0,0,2"/>
            <Entry x:Name="txtUsername" Placeholder="Enter your username"
                   Style="{StaticResource ModernEntry}"/>

            <!-- Password -->
            <Label x:Name="lblPassword" Text="Password" TextColor="{StaticResource TextSecondary}"
                   FontSize="13" FontAttributes="Bold" Margin="2,6,0,2"/>
            <Entry x:Name="txtPassword" Placeholder="Enter your password" IsPassword="True"
                   Style="{StaticResource ModernEntry}"/>

            <!-- Email (register mode only) -->
            <Label x:Name="lblEmail" Text="E-mail" TextColor="{StaticResource TextSecondary}"
                   FontSize="13" FontAttributes="Bold" Margin="2,6,0,2" IsVisible="False"/>
            <Entry x:Name="txtEmail" Placeholder="Enter your e-mail" IsVisible="False"
                   Style="{StaticResource ModernEntry}"/>

            <!-- Buttons -->
            <Grid ColumnDefinitions="*,12,*" Margin="0,16,0,0">
                <Button x:Name="btnLogin" Grid.Column="0" Text="Login"
                        Style="{StaticResource PrimaryBtn}" HeightRequest="46"/>
                <Button x:Name="btnRegister" Grid.Column="2" Text="Register"
                        Style="{StaticResource SuccessBtn}" HeightRequest="46"/>
            </Grid>

            <Label x:Name="lblStatus" Text="" FontSize="12" HorizontalOptions="Center"
                   Margin="0,4,0,0"/>
        </VerticalStackLayout>
    </Border>
</ContentPage>
