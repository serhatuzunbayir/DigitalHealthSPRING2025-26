<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DigitalHealthTrainer.Forms.DashboardForm"
        Title="Digital Health Trainer - Dashboard"
        Width="1050" Height="650"
        WindowStartupLocation="CenterScreen"
        MinWidth="900" MinHeight="500">

    <Grid ColumnDefinitions="220,*">

        <!-- ===== SIDEBAR ===== -->
        <Border Grid.Column="0" Background="#1E293B" Padding="16">
            <Grid RowDefinitions="Auto,Auto,*,Auto">

                <!-- App Logo -->
                <StackPanel Grid.Row="0" Margin="0,4,0,24">
                    <TextBlock Text="💪" FontSize="32" HorizontalAlignment="Center"/>
                    <TextBlock Text="Digital Health" FontSize="16" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    <TextBlock Text="Trainer Panel" FontSize="11" Foreground="#64748B"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Trainer info -->
                <Border Grid.Row="1" Background="#334155" CornerRadius="10" Padding="12" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock x:Name="lblTrainerName" Text="Trainer" FontSize="14"
                                   FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock x:Name="lblTrainerEmail" Text="email@mail.com" FontSize="11"
                                   Foreground="#94A3B8"/>
                    </StackPanel>
                </Border>

                <!-- Navigation -->
                <StackPanel Grid.Row="2" Spacing="4">
                    <TextBlock Text="MENU" FontSize="10" Foreground="#475569"
                               FontWeight="Bold" Margin="8,0,0,6"/>
                    <Button x:Name="btnDashboard" Content="📊  Dashboard" Classes="nav-active"/>
                    <Button x:Name="btnWorkouts" Content="🏋️  Workouts" Classes="nav"/>
                    <Button x:Name="btnSessions" Content="📅  Sessions" Classes="nav"/>
                    <Button x:Name="btnReports" Content="📈  Reports" Classes="nav"/>
                </StackPanel>

                <!-- Bottom: Language + Logout -->
                <StackPanel Grid.Row="3" Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock x:Name="lblLanguage" Text="🌐" Foreground="#94A3B8"
                                   VerticalAlignment="Center"/>
                        <ComboBox x:Name="cmbLanguage" Classes="modern" Width="130"
                                  SelectedIndex="0" FontSize="12">
                            <ComboBoxItem Content="English"/>
                            <ComboBoxItem Content="Türkçe"/>
                        </ComboBox>
                    </StackPanel>
                    <Button x:Name="btnLogout" Content="🚪  Logout" Classes="nav"
                            Foreground="#F87171"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== MAIN CONTENT ===== -->
        <ScrollViewer Grid.Column="1">
            <StackPanel Margin="28,20,28,28" Spacing="20">

                <!-- Page Header -->
                <Grid>
                    <TextBlock x:Name="lblPageTitle" Text="Dashboard" Classes="page-title"/>
                    <Button x:Name="btnRefresh" Content="⟳  Refresh" Classes="primary"
                            HorizontalAlignment="Right"/>
                </Grid>

                <!-- Stat Cards Row -->
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <Border Classes="stat-card">
                        <StackPanel>
                            <TextBlock Text="👥" FontSize="20"/>
                            <TextBlock x:Name="lblTotalClients" Text="0" Classes="stat-value"
                                       Foreground="#4F46E5"/>
                            <TextBlock x:Name="lblTotalClientsLabel" Text="Total Clients"
                                       Classes="stat-label"/>
                        </StackPanel>
                    </Border>
                    <Border Classes="stat-card">
                        <StackPanel>
                            <TextBlock Text="🎯" FontSize="20"/>
                            <TextBlock x:Name="lblTotalActiveGoals" Text="0" Classes="stat-value"
                                       Foreground="#059669"/>
                            <TextBlock x:Name="lblActiveGoalsLabel" Text="Active Goals"
                                       Classes="stat-label"/>
                        </StackPanel>
                    </Border>
                    <Border Classes="stat-card">
                        <StackPanel>
                            <TextBlock Text="📊" FontSize="20"/>
                            <TextBlock x:Name="lblAvgAdherence" Text="0%" Classes="stat-value"
                                       Foreground="#D97706"/>
                            <TextBlock x:Name="lblAvgAdherenceLabel" Text="Avg Adherence"
                                       Classes="stat-label"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Client Table -->
                <Border Classes="card" Padding="0">
                    <StackPanel>
                        <TextBlock x:Name="lblAssignedClients" Text="Assigned Clients"
                                   Classes="section-title" Margin="20,16,20,12"/>
                        <DataGrid x:Name="dgClients" AutoGenerateColumns="False"
                                  IsReadOnly="True" CanUserResizeColumns="True"
                                  CanUserSortColumns="True" MinHeight="200"
                                  Margin="8,0,8,8">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Client" Binding="{Binding Username}" Width="140"/>
                                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="180"/>
                                <DataGridTextColumn Header="Last Activity" Binding="{Binding LastActivityDisplay}" Width="120"/>
                                <DataGridTextColumn Header="Weekly Exercises" Binding="{Binding WeeklyExerciseCount}" Width="130"/>
                                <DataGridTextColumn Header="Adherence %" Binding="{Binding AdherenceDisplay}" Width="110"/>
                                <DataGridTextColumn Header="Active Goals" Binding="{Binding ActiveGoals}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
