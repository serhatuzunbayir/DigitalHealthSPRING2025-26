<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DigitalHealthTrainer.Forms.LoginForm"
        Title="Digital Health Trainer"
        Width="440" Height="520"
        WindowStartupLocation="CenterScreen"
        CanResize="False">

    <Grid RowDefinitions="Auto,*">

        <!-- Language selector top-right -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,12,20,0" Spacing="6">
            <TextBlock x:Name="lblLanguage" Text="Language:" Classes="label"
                       VerticalAlignment="Center"/>
            <ComboBox x:Name="cmbLanguage" Classes="modern" Width="110" SelectedIndex="0">
                <ComboBoxItem Content="English"/>
                <ComboBoxItem Content="Türkçe"/>
            </ComboBox>
        </StackPanel>

        <!-- Login Card -->
        <Border Grid.Row="1" Classes="card" Margin="40,10,40,40" VerticalAlignment="Center">
            <StackPanel Spacing="6">

                <!-- Logo area -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,10">
                    <TextBlock Text="💪" FontSize="40" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="lblTitle" Text="Trainer Login"
                               FontSize="24" FontWeight="Bold" Foreground="#4F46E5"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    <TextBlock Text="Digital Health &amp; Fitness Tracker"
                               FontSize="12" Foreground="#94A3B8"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Username -->
                <TextBlock x:Name="lblUsername" Text="Username:" Classes="label"/>
                <TextBox x:Name="txtUsername" Classes="modern" Watermark="Enter your username"/>

                <!-- Password -->
                <TextBlock x:Name="lblPassword" Text="Password:" Classes="label" Margin="0,8,0,4"/>
                <TextBox x:Name="txtPassword" Classes="modern" PasswordChar="●"
                         Watermark="Enter your password"/>

                <!-- Email (register mode) -->
                <TextBlock x:Name="lblEmail" Text="E-mail:" Classes="label"
                           IsVisible="False" Margin="0,8,0,4"/>
                <TextBox x:Name="txtEmail" Classes="modern" Watermark="Enter your e-mail"
                         IsVisible="False"/>

                <!-- Buttons -->
                <Grid Margin="0,16,0,0" ColumnDefinitions="*,12,*">
                    <Button x:Name="btnLogin" Grid.Column="0" Content="Login"
                            Classes="primary" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center" Height="44"/>
                    <Button x:Name="btnRegister" Grid.Column="2" Content="Register"
                            Classes="success" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center" Height="44"/>
                </Grid>

                <!-- Status -->
                <TextBlock x:Name="lblStatus" Text="" FontSize="12"
                           HorizontalAlignment="Center" Margin="0,8,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
